# Скопируйте этот файл в .env и заполните реальными значениями.
# Файл .env не попадает ни в git, ни в Docker-образ; docker compose
# автоматически подхватит его при `docker compose up` из той же папки,
# где лежит docker-compose.yml.

# Telegram-бот для уведомлений о новых заявках.
# Токен получите у @BotFather, chat_id — у @userinfobot или из getUpdates.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
