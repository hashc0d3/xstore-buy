# Опционально: скопируйте в .env рядом с docker-compose.yml, если нужно переопределить порты или домены.
# Без этого файла деплой работает из коробки: cd /opt/xstore-buy && git pull origin main && docker compose up -d --build

# Уникальное имя проекта (контейнеры и сеть не пересекутся с xstore на том же хосте)
COMPOSE_PROJECT_NAME=sotik77

# Порт web на loopback (только число; nginx proxy_pass на 127.0.0.1:этот_порт)
# Если при up ошибка «port is already allocated» — ss/docker ps, compose down, или другой порт + nginx
WEB_HOST_PORT=8083

# Сборка Next.js (вшиваются в бандл при docker compose build)
NEXT_PUBLIC_SITE_URL=https://www.sotik77.ru
NEXT_PUBLIC_STORE_BRAND=sotik77
NEXT_PUBLIC_API_URL=/api
API_INTERNAL_URL=http://api:4000

# Ссылка на отзывы на Авито (вшивается при сборке web). Пусто — дефолт из web/src/lib/brand.ts
# NEXT_PUBLIC_SOTIK_AVITO_REVIEWS_URL=https://www.avito.ru/brands/i131720364

# Разрешённые origin для браузерных запросов к API (свой домен + локальная отладка)
CORS_ORIGIN=https://www.sotik77.ru,https://sotik77.ru,http://127.0.0.1:8083,http://localhost:8083

# Telegram: две отдельные строки (между ними Enter, не «>»).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Опционально
# AUTO_SEED_CATALOG=1
