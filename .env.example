# Скопируйте в .env рядом с docker-compose.yml (/opt/xstore).
# Каждая переменная — отдельная строка. Между TELEGRAM_BOT_TOKEN и
# TELEGRAM_CHAT_ID должен быть перевод строки (не «>» и не пробел вместо Enter).

# Уникально на сервере, если рядом стоит xstore-buy: иначе Docker смешает
# контейнеры, сеть и volume api-data между проектами.
COMPOSE_PROJECT_NAME=xstore55

# Порт web на loopback (только число). Должен совпадать с proxy_pass в nginx.
WEB_HOST_PORT=8080

# Вшиваются в Next.js при `docker compose build` (после смены — build web).
NEXT_PUBLIC_SITE_URL=https://www.xstore55.ru
NEXT_PUBLIC_STORE_BRAND=xstore
NEXT_PUBLIC_API_URL=/api
API_INTERNAL_URL=http://api:4000

CORS_ORIGIN=https://www.xstore55.ru,https://xstore55.ru,http://127.0.0.1:8080,http://localhost:8080

# Две строки, каждая со своим именем:
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Опционально
# AUTO_SEED_CATALOG=1
